# npm run build/preview/deploy use Vite's "production" mode, and this repo's
# only production build target is the static GitHub Pages export (no backend
# deploys there — see docs/DEV/readme-pub-github.md). Skip the login gate so
# the read-only viewer pages (Home, Graph, Book, About, Resources) are
# actually reachable; API-dependent actions (Settings saves, generation) still
# fail quietly since there's no backend to call.
VITE_PUBLIC_READONLY=true
