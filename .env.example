# Google OAuth — reuse the zinets_vis OAuth client from Google Cloud Console
# (APIs & Services → Credentials). Local files in zinets_vis only contain
# placeholders; copy the real values from the Console or your deployed server.
# The callback path/port matches zinets_vis dev, so the existing authorized
# redirect URI (http://localhost:8000/api/auth/google/callback) works as-is.
CB_GOOGLE_CLIENT_ID=
CB_GOOGLE_CLIENT_SECRET=
# CB_GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
# CB_FRONTEND_URL=http://localhost:5173/cb-zinets/
# CB_SESSION_SECRET=            # optional; random per boot if unset
